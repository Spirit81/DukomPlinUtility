<UserControl x:Class="DukomPlinUtility.Views.WalkByView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F57C00" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#F57C00" />
        </Style>

        <Style x:Key="PreviewRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusLevel}" Value="OK">
                    <Setter Property="Background" Value="#EAF7EA" />
                    <Setter Property="Foreground" Value="#1B5E20" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="Warning">
                    <Setter Property="Background" Value="#FFF4D6" />
                    <Setter Property="Foreground" Value="#9A6500" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusLevel}" Value="Error">
                    <Setter Property="Background" Value="#FFE1E1" />
                    <Setter Property="Foreground" Value="#B00020" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Holosys WalkBy" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10" />

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="1. Odaberi XML obilazak" FontWeight="Bold" />
                        <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" Background="Transparent" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="Xml_Drop">
                            <TextBlock Text="XML&#10;Povuci ovdje ili klikni Browse" TextAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00" IsHitTestVisible="False" />
                        </Border>
                        <DockPanel>
                            <Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseXmlCommand}" />
                            <TextBox Text="{Binding XmlFile, UpdateSourceTrigger=PropertyChanged}" ToolTip="Odaberi XML dobiven iz Holosys WalkBy sustava." />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="2. Source iz Postavki" FontWeight="Bold" />
                        <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10">
                            <TextBlock Text="{Binding SourceText}" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="#2E7D32" />
                        </Border>
                        <Button Content="Otvori Postavke" Command="{Binding OpenSettingsCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="3. Odaberi izlaznu mapu" FontWeight="Bold" />
                        <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" Background="Transparent" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="Output_Drop">
                            <TextBlock Text="Mapa&#10;Povuci ovdje ili klikni Browse" TextAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00" IsHitTestVisible="False" />
                        </Border>
                        <DockPanel>
                            <Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseOutputCommand}" />
                            <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource OrangeButton}" Content="▶ POKRENI WALKBY" Width="220" Command="{Binding RunCommand}" />
                <Button Content="Otvori izlaznu mapu" Command="{Binding OpenOutputCommand}" />
                <TextBlock Text="{Binding StatsText}" Margin="20,8" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Pregled rezultata" FontWeight="Bold" FontSize="17" Margin="0,0,0,8" />

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PreviewItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          RowStyle="{StaticResource PreviewRowStyle}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User Code" Binding="{Binding UserCode}" Width="110" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="Meter" Binding="{Binding Meter}" Width="120" />
                        <DataGridTextColumn Header="Reading" Binding="{Binding Reading}" Width="100" />
                        <DataGridTextColumn Header="Previous" Binding="{Binding PreviousReading}" Width="100" />
                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
