<UserControl x:Class="DukomPlinUtility.Views.WalkByView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,4,0,18">
            <TextBlock Text="🚶" FontSize="42" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <StackPanel>
                <TextBlock Text="WalkBy" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Holosys WalkBy obrada i pregled rezultata" FontSize="15" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
        </DockPanel>

        <!-- Input card -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="330" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="XML datoteka" FontWeight="Bold" Margin="0,0,0,5" />
                    <Border Style="{StaticResource DropZone}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Xml_Drop" Margin="0,0,0,8">
                        <TextBlock Text="Povuci XML ovdje ili klikni ikonu mape" TextAlignment="Center" Foreground="{StaticResource AccentBrush}" IsHitTestVisible="False" />
                    </Border>
                    <DockPanel Margin="0,0,0,10" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Xml_Drop">
                        <Button DockPanel.Dock="Right" Content="📁" Width="48" Command="{Binding BrowseXmlCommand}" />
                        <TextBox Text="{Binding XmlFile, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Xml_Drop" ToolTip="Odaberi XML dobiven iz Holosys WalkBy sustava." />
                    </DockPanel>

                    <TextBlock Text="Izlazna mapa" FontWeight="Bold" Margin="0,0,0,5" />
                    <Border Style="{StaticResource DropZone}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Output_Drop" Margin="0,0,0,8">
                        <TextBlock Text="Povuci izlaznu mapu ovdje" TextAlignment="Center" Foreground="{StaticResource OrangeBrush}" IsHitTestVisible="False" />
                    </Border>
                    <DockPanel AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Output_Drop">
                        <Button DockPanel.Dock="Right" Content="📁" Width="48" Command="{Binding BrowseOutputCommand}" />
                        <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Output_Drop" />
                    </DockPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Shared Source (Postavke)" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding SourceText}" Foreground="{StaticResource GreenBrush}" FontSize="16" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <Button Content="⚙  Postavke" Command="{Binding OpenSettingsCommand}" Height="42" Margin="4" />
                    <Button Content="📁  Otvori izlaznu mapu" Command="{Binding OpenOutputCommand}" Height="42" Margin="4" />
                    <Button Style="{StaticResource PrimaryButton}" Content="▶  Pokreni obradu" Command="{Binding RunCommand}" Height="46" Margin="4" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Metrics -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="XML zapisi" FontWeight="Bold" TextAlignment="Center" />
                    <TextBlock Text="{Binding XmlCountText}" Style="{StaticResource MetricValueBlue}" />
                </StackPanel>
                <Border Grid.Column="1" BorderBrush="#D8DEE7" BorderThickness="1,0,0,0" Padding="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Matched (OK)" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock Text="{Binding MatchedText}" Style="{StaticResource MetricValueGreen}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="#D8DEE7" BorderThickness="1,0,0,0" Padding="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Missing" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock Text="{Binding MissingText}" Style="{StaticResource MetricValueRed}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" BorderBrush="#D8DEE7" BorderThickness="1,0,0,0" Padding="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Uspješnost" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock Text="{Binding SuccessText}" Style="{StaticResource MetricValueBlue}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" BorderBrush="#D8DEE7" BorderThickness="1,0,0,0" Padding="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Vrijeme obrade" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock Text="{Binding DurationText}" FontSize="22" FontWeight="SemiBold" TextAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" BorderBrush="#D8DEE7" BorderThickness="1,0,0,0" Padding="20,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Zadnje pokretanje" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock Text="{Binding LastRunText}" FontSize="16" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Result preview -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Pregled rezultata" FontSize="22" FontWeight="Bold" Margin="0,0,18,0" />
                    <TextBlock Grid.Column="1" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Content="Sve" Style="{StaticResource PrimaryButton}" MinWidth="90" Padding="12,8" Command="{Binding ShowAllCommand}" />
                    <Button Grid.Column="3" Content="OK" MinWidth="90" Command="{Binding ShowOkCommand}" />
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="Warning" MinWidth="110" Foreground="{StaticResource WarningBrush}" Command="{Binding ShowWarningCommand}" />
                        <Button Content="Error" MinWidth="90" Foreground="{StaticResource RedBrush}" Command="{Binding ShowErrorCommand}" />
                    </StackPanel>
                    <TextBox Grid.Column="5" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Pretraži po User Code, korisniku, brojilu, stanju, datumu ili statusu." />
                    <TextBlock Grid.Column="6" Text="{Binding PreviewTotalText}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PreviewView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          RowStyle="{StaticResource ValidationRowStyle}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User Code" Binding="{Binding UserCode}" Width="120" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="170" />
                        <DataGridTextColumn Header="Meter" Binding="{Binding Meter}" Width="130" />
                        <DataGridTextColumn Header="Reading" Binding="{Binding Reading}" Width="120" />
                        <DataGridTextColumn Header="Previous Reading" Binding="{Binding PreviousReading}" Width="160" />
                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="130" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Output footer -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📄 output.txt" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="📄 result.txt" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="📄 missing.txt" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="📄 walkby.log" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" Text="✓ Obrada završena uspješno." Foreground="{StaticResource GreenBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
