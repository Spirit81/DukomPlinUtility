<UserControl x:Class="DukomPlinUtility.Views.WalkByView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F57C00" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#F57C00" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Holosys WalkBy" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10" />
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="1. Odaberi XML obilazak" FontWeight="Bold"/>
                    <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="Xml_Drop">
                        <TextBlock Text="XML&#10;Povuci ovdje ili klikni Browse" TextAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00"/>
                    </Border>
                    <DockPanel><Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseXmlCommand}"/><TextBox Text="{Binding XmlFile, UpdateSourceTrigger=PropertyChanged}" ToolTip="Odaberi XML dobiven iz Holosys WalkBy sustava."/></DockPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="15,0">
                    <TextBlock Text="2. Source iz Postavki" FontWeight="Bold"/>
                    <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10"><TextBlock Text="{Binding SourceText}" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/></Border>
                    <Button Content="Otvori Postavke" Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="3. Odaberi izlaznu mapu" FontWeight="Bold"/>
                    <Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="Output_Drop"><TextBlock Text="Mapa&#10;Povuci ovdje ili klikni Browse" TextAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00"/></Border>
                    <DockPanel><Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseOutputCommand}"/><TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"/></DockPanel>
                </StackPanel>
            </Grid>
        </Border>
        <Border Style="{StaticResource Card}"><StackPanel Orientation="Horizontal"><Button Style="{StaticResource OrangeButton}" Content="▶ POKRENI WALKBY" Width="220" Command="{Binding RunCommand}"/><Button Content="Otvori izlaznu mapu" Command="{Binding OpenOutputCommand}"/><TextBlock Text="{Binding StatsText}" Margin="20,8" FontWeight="Bold"/></StackPanel></Border>
    </StackPanel>
</UserControl>
