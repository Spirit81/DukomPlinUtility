<UserControl x:Class="DukomPlinUtility.Views.ZgradeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,4,0,18">
            <TextBlock Text="🏢" FontSize="42" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <StackPanel>
                <TextBlock Text="Zgrade" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Spajanje TXT očitanja i kontrola prema zajedničkom Sourceu" FontSize="15" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Zgrade_Drop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="TXT fajlovi zgrada" FontWeight="Bold" Margin="0,0,0,6" />
                    <Border Style="{StaticResource DropZone}" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Zgrade_Drop" Margin="0,0,0,10">
                        <TextBlock Text="Povuci TXT fajlove ovdje ili koristi Dodaj TXT fajlove. Drag &amp; drop ovdje ne mijenja Shared Source." TextAlignment="Center" Foreground="{StaticResource AccentBrush}" IsHitTestVisible="False" TextWrapping="Wrap" />
                    </Border>
                    <ListBox ItemsSource="{Binding Files}" Height="100" BorderBrush="#CBD3DD" AllowDrop="True" PreviewDragOver="File_DragOver" PreviewDrop="Zgrade_Drop" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="22,0,0,0" VerticalAlignment="Center">
                    <Button Content="📄  Dodaj TXT fajlove" Command="{Binding BrowseFilesCommand}" Height="42" Margin="4" />
                    <Button Content="🧹  Clear" Command="{Binding ClearCommand}" Height="42" Margin="4" />
                    <Button Style="{StaticResource PrimaryButton}" Content="▶  Pokreni provjeru" Command="{Binding RunCommand}" Height="46" Margin="4" />
                    <Button Content="📁  Otvori izlaz" Command="{Binding OpenOutputCommand}" Height="42" Margin="4" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Pregled grešaka / upozorenja" FontSize="22" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="{Binding StatsText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Issues}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowStyle="{StaticResource ValidationRowStyle}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User Code" Binding="{Binding UserCode}" Width="120" />
                        <DataGridTextColumn Header="Brojilo" Binding="{Binding Meter}" Width="140" />
                        <DataGridTextColumn Header="Source stanje" Binding="{Binding SourceReading}" Width="130" />
                        <DataGridTextColumn Header="Novo stanje" Binding="{Binding NewReading}" Width="130" />
                        <DataGridTextColumn Header="Razlika" Binding="{Binding Difference}" Width="110" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📄 zgrade_merged.txt" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="📄 zgrade_mismatch.txt" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="📄 zgrade.log" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="✓ Kontrole završene." Foreground="{StaticResource GreenBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
