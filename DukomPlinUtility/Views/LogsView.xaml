<UserControl x:Class="DukomPlinUtility.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Logovi" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10"/>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <Button Content="Učitaj log" Command="{Binding OpenLogCommand}" Width="120" HorizontalAlignment="Left"/>
                <TextBox Text="{Binding LogText, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="620"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
