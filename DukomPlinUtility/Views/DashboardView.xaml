<UserControl x:Class="DukomPlinUtility.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10" />
        <UniformGrid Columns="3">
            <Border Style="{StaticResource Card}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenWalkByCommand}" />
                </Border.InputBindings>
                <StackPanel><TextBlock Text="📡 WalkBy" FontSize="22" FontWeight="Bold"/><TextBlock Text="Holosys WalkBy XML + ZaRtf.txt" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenNbIotCommand}" />
                </Border.InputBindings>
                <StackPanel><TextBlock Text="📶 NB-IoT" FontSize="22" FontWeight="Bold"/><TextBlock Text="Web export konverzija i kontrole" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenZgradeCommand}" />
                </Border.InputBindings>
                <StackPanel><TextBlock Text="🏢 Zgrade" FontSize="22" FontWeight="Bold"/><TextBlock Text="Spajanje očitanja zgrada i provjere" Margin="0,8,0,0"/></StackPanel>
            </Border>
        </UniformGrid>
        <Border Style="{StaticResource Card}" Cursor="Arrow">
            <StackPanel>
                <TextBlock Text="Shared Source (ZaRtf.txt)" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="{Binding SourceText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                <Button Content="Otvori Postavke" Command="{Binding OpenSettingsCommand}" Width="140" HorizontalAlignment="Left" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
