<UserControl x:Class="DukomPlinUtility.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F57C00" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#F57C00" />
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#22A735" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#22A735" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10" />
        <UniformGrid Columns="3">
            <Border Style="{StaticResource Card}" MouseLeftButtonUp="WalkByCard_MouseLeftButtonUp">
                <StackPanel><TextBlock Text="📡 WalkBy" FontSize="22" FontWeight="Bold"/><TextBlock Text="Holosys WalkBy XML + ZaRtf.txt" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" MouseLeftButtonUp="NbIotCard_MouseLeftButtonUp">
                <StackPanel><TextBlock Text="📶 NB-IoT" FontSize="22" FontWeight="Bold"/><TextBlock Text="Web export konverzija i kontrole" Margin="0,8,0,0"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" MouseLeftButtonUp="ZgradeCard_MouseLeftButtonUp">
                <StackPanel><TextBlock Text="🏢 Zgrade" FontSize="22" FontWeight="Bold"/><TextBlock Text="Spajanje očitanja zgrada i provjere" Margin="0,8,0,0"/></StackPanel>
            </Border>
        </UniformGrid>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Shared Source (ZaRtf.txt)" FontSize="18" FontWeight="Bold" />
                <TextBlock x:Name="LblDashboardSource" Margin="0,8,0,0" Text="Source nije postavljen" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
