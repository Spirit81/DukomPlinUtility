<UserControl x:Class="DukomPlinUtility.Views.NbIotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#22A735" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#22A735" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="NB-IoT Export" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10" />
        <Border Style="{StaticResource Card}">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="300"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"><TextBlock Text="1. Odaberi XLS/XLSX/TXT export" FontWeight="Bold"/><Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="NbIot_Drop"><TextBlock Text="Povuci NB-IoT export ovdje" TextAlignment="Center" VerticalAlignment="Center" Foreground="#22A735"/></Border><DockPanel><Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseInputCommand}"/><TextBox Text="{Binding InputFile, UpdateSourceTrigger=PropertyChanged}"/></DockPanel></StackPanel>
                <StackPanel Grid.Column="1" Margin="15,0"><TextBlock Text="2. Očekivani datum očitanja" FontWeight="Bold"/><DatePicker SelectedDate="{Binding ExpectedDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,10"/><CheckBox Content="Zamijeni hrvatske znakove" IsChecked="{Binding NormalizeCroatian}" Margin="0,20"/></StackPanel>
                <StackPanel Grid.Column="2"><TextBlock Text="3. Izlazna mapa" FontWeight="Bold"/><Border BorderBrush="#CDD3DA" BorderThickness="1" CornerRadius="6" Height="115" Margin="0,10" AllowDrop="True" PreviewDragOver="File_DragOver" Drop="Output_Drop"><TextBlock Text="Povuci mapu ovdje" TextAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00"/></Border><DockPanel><Button Content="📁" DockPanel.Dock="Right" Command="{Binding BrowseOutputCommand}"/><TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"/></DockPanel></StackPanel>
            </Grid>
        </Border>
        <Border Style="{StaticResource Card}"><StackPanel Orientation="Horizontal"><Button Style="{StaticResource GreenButton}" Content="☁ IZVEZI NB-IoT" Width="200" Command="{Binding RunCommand}"/><Button Content="Otvori izlaz" Command="{Binding OpenOutputCommand}"/><TextBlock Text="{Binding StatsText}" Margin="20,8" FontWeight="Bold"/></StackPanel></Border>
    </StackPanel>
</UserControl>
