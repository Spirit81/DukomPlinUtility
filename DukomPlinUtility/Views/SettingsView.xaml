<UserControl x:Class="DukomPlinUtility.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F57C00" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#F57C00" />
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#22A735" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#22A735" />
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Postavke" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="10"/>
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Shared Source (ZaRtf.txt iz KODING-a - STA + PRI)" FontWeight="Bold"/>
                <DockPanel Margin="0,8"><Button Content="Browse" DockPanel.Dock="Right" Click="BrowseSource_Click"/><TextBox x:Name="TxtSharedSource" ToolTip="Ovdje učitati ZaRtf.txt očitačku listu iz KODING-a - STA + PRI."/></DockPanel>
                <TextBlock Text="Koristi se za WalkBy, NB-IoT i Zgrade module." Foreground="#555"/>
                <Button Content="Spremi postavke" Width="150" Margin="0,18,0,0" HorizontalAlignment="Left" Click="SaveSettings_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
