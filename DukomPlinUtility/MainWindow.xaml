<Window x:Class="DukomPlinUtility.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DukomPlinUtility.Views"
        xmlns:vm="clr-namespace:DukomPlinUtility.ViewModels"
        Title="Dukom Plin Utility" Height="950" Width="1800"
        MinHeight="850" MinWidth="1400" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WalkByViewModel}">
            <views:WalkByView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NbIotViewModel}">
            <views:NbIotView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ZgradeViewModel}">
            <views:ZgradeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView />
        </DataTemplate>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="20,14" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F2F6FA" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2531" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0B63D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="#0F1822">
            <DockPanel LastChildFill="True">
                <!-- Brand header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,26,0,0">
                    <Image Source="Assets/logo.png"
                           Width="112"
                           Height="96"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                    <TextBlock Text="DUKOM PLIN"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="UTILITY"
                               Foreground="#2F8CFF"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0" />

                    <Separator Margin="18,18,18,16"
                               Background="#E5EDF7"
                               Opacity="0.85" />
                </StackPanel>

                <!-- Navigation buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,0">
                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Dashboard" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="WalkBy">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE726;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="WalkBy" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="NbIot">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xEC3F;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="NB-IoT" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="Zgrade">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE80C;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Zgrade" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="Logs">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Logs" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Settings" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCommand}" CommandParameter="About">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="About" FontSize="17" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Sidebar footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="22,0,22,26">
                    <TextBlock Text="DUKOM PLIN Utility"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />
                    <TextBlock Text="v1.3.3"
                               Foreground="#D6DEE8"
                               FontSize="14"
                               TextAlignment="Center"
                               Margin="0,4,0,24" />
                    <TextBlock Text="● Ready"
                               Foreground="#35B84A"
                               FontWeight="Bold"
                               FontSize="14" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Background="#F3F6FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <ContentControl Grid.Row="0" Content="{Binding CurrentViewModel}" />

            <Border Grid.Row="1" Background="#111820" BorderBrush="#0A0F14" BorderThickness="1,0,0,0" Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="● Ready" Foreground="#35B84A" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Shared Source:" Foreground="White" Margin="0,0,10,0" />
                        <TextBlock Text="● OK" Foreground="#35B84A" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding StatusDetails}" Foreground="#E9EEF5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="Verzija: v1.3.3" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="4" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="12" VerticalAlignment="Center" Margin="14,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
