<Application x:Class="DukomPlinUtility.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#F57C00" />
        <SolidColorBrush x:Key="GreenBrush" Color="#22A735" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BgBrush" Color="#F6F7F9" />
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#D7DCE2" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#D7DCE2" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4" />
        </Style>
    </Application.Resources>
</Application>
